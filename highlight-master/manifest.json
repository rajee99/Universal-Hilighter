{
  "manifest_version": 3,
  "name": "HighlightMaster - Universal Text Highlighter",
  "version": "2.3.0",
  "description": "Highlight text on any website with persistent colors, quick keyboard shortcuts, personal notes, filters/sort, and full React/SPA compatibility.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "windows"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "HighlightMaster",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

